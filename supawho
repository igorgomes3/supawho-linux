#!/bin/bash
# supawho - Manage multiple Supabase accounts securely via macOS Keychain

VERSION="1.3.0"
KEYCHAIN_SERVICE="supabase-cli-accounts"
KEYCHAIN_INDEX_KEY="_account_list"

show_banner() {
  local green=$'\033[1;32m'
  local reset=$'\033[0m'
  echo -e "\n${green}   ___  _   _ ___  ___  _    _ _  _  ___${reset}"
  echo -e "${green}  / __|| | | | _ \/ _ \| |  | | || |/ _ \\\\${reset}"
  echo -e "${green}  \__ \| |_| |  _/ (_) | |/\| | __ | (_)${reset}"
  echo -e "${green}  |___/ \___/|_|  \__\_\__/\__|_||_|\___/${reset}"
  echo -e "\n     🔍 Who are you today?\n"
}

# --- Helpers ---

get_account_list() {
  security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_INDEX_KEY" -w 2>/dev/null
}

save_account_list() {
  local list="$1"
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_INDEX_KEY" 2>/dev/null
  security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_INDEX_KEY" -w "$list"
}

get_token() {
  local name="$1"
  security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" -w 2>/dev/null
}

# --- Commands ---

cmd_guided_add() {
  echo -e "  No accounts found. Let's add your first one!\n"
  echo -e "  Get your token here:\n  → https://supabase.com/dashboard/account/tokens\n"
  
  read -rp "  Account name (e.g. myproject): " name
  [[ -z "$name" ]] && echo "  Aborted." && exit 1
  
  read -rp "  Access token (sbp_...): " token
  [[ -z "$token" ]] && echo "  Aborted." && exit 1
  
  cmd_add "$name" "$token"
  
  local login_prompt="\n  Login now as '$name'? [Y/n] "
  read -rp "$login_prompt" confirm
  if [[ -z "$confirm" || "$confirm" =~ ^[Yy]$ ]]; then
    cmd_use "$name"
  fi
}

cmd_add() {
  local name="$1"
  local token="$2"

  if [[ -z "$name" || -z "$token" ]]; then
    show_banner
    cmd_guided_add
    exit 0
  fi

  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" 2>/dev/null
  security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" -w "$token"

  local list
  list=$(get_account_list)
  if [[ -z "$list" ]]; then
    list="$name"
  elif ! echo "$list" | tr ',' '\n' | grep -qx "$name"; then
    list="$list,$name"
  fi
  save_account_list "$list"

  echo "Account '$name' saved to Keychain."
}

cmd_rename() {
  local old_name="$1"
  local new_name="$2"

  if [[ -z "$old_name" ]]; then
    local list
    list=$(get_account_list)
    [[ -z "$list" ]] && echo "No accounts saved." && exit 1

    local accounts=()
    IFS=',' read -ra accounts <<< "$list"

    show_banner
    echo -e "Select account to rename:\n"
    for i in "${!accounts[@]}"; do
      echo "  $((i + 1))) ${accounts[$i]}"
    done

    read -rp $'\nEnter number (1-'"${#accounts[@]}"'): ' choice
    if [[ -z "$choice" || "$choice" -lt 1 || "$choice" -gt "${#accounts[@]}" ]] 2>/dev/null; then
      echo "Invalid selection."
      exit 1
    fi
    old_name="${accounts[$((choice - 1))]}"
  fi

  if [[ -z "$new_name" ]]; then
    read -rp "  New name for '$old_name': " new_name
    [[ -z "$new_name" ]] && echo "  Aborted." && exit 1

    read -rp "  Rename '$old_name' → '$new_name'? [Y/n] " confirm
    if [[ -n "$confirm" && ! "$confirm" =~ ^[Yy]$ ]]; then
      echo "  Aborted."
      exit 0
    fi
  fi

  local token
  token=$(get_token "$old_name")
  if [[ -z "$token" ]]; then
    echo "Account '$old_name' not found."
    exit 1
  fi

  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$new_name" 2>/dev/null
  security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$new_name" -w "$token"
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$old_name" 2>/dev/null

  local list
  list=$(get_account_list)
  list=$(echo "$list" | tr ',' '\n' | sed "s/^${old_name}$/${new_name}/" | paste -sd ',' -)
  save_account_list "$list"

  echo "Account '$old_name' renamed to '$new_name'."
}

cmd_remove() {
  local name="$1"
  [[ -z "$name" ]] && echo "Usage: supawho remove <name>" && exit 1

  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" 2>/dev/null

  local list
  list=$(get_account_list)
  list=$(echo "$list" | tr ',' '\n' | grep -vx "$name" | paste -sd ',' -)
  save_account_list "$list"

  echo "Account '$name' removed."
}

cmd_list() {
  local list
  list=$(get_account_list)

  if [[ -z "$list" ]]; then
    echo -e "No accounts saved. Add one with:\n  supawho add <name> <token>"
    exit 0
  fi

  echo "Saved accounts:"
  echo "$list" | tr ',' '\n' | while read -r name; do
    echo "  - $name"
  done
}

cmd_use() {
  local name="$1"
  [[ -z "$name" ]] && echo "Usage: supawho use <name>" && exit 1

  local token
  token=$(get_token "$name")
  if [[ -z "$token" ]]; then
    echo "Account '$name' not found. Run 'supawho list' to see saved accounts."
    exit 1
  fi

  echo "Logging in as '$name'..."
  supabase login --token "$token"
  echo "Logged in as '$name'."
}

cmd_interactive() {
  local list
  list=$(get_account_list)

  show_banner
  [[ -z "$list" ]] && cmd_guided_add && exit 0

  local accounts=()
  IFS=',' read -ra accounts <<< "$list"

  echo -e "Select an account:\n"
  for i in "${!accounts[@]}"; do
    echo "  $((i + 1))) ${accounts[$i]}"
  done
  
  local select_prompt="\nEnter number (1-${#accounts[@]}): "
  read -rp "$select_prompt" choice

  if [[ -z "$choice" || "$choice" -lt 1 || "$choice" -gt "${#accounts[@]}" ]] 2>/dev/null; then
    echo "Invalid selection."
    exit 1
  fi

  cmd_use "${accounts[$((choice - 1))]}"
}

# --- Main ---

case "${1:-}" in
  add)             cmd_add "$2" "$3" ;;
  rename)          cmd_rename "$2" "$3" ;;
  remove)          cmd_remove "$2" ;;
  list)            cmd_list ;;
  use)             cmd_use "$2" ;;
  version|--version|-v) echo "supawho ${VERSION}" ;;
  help|--help|-h)
    show_banner
    echo -e "Usage:"
    echo "  supawho                       Interactive account selection"
    echo "  supawho add <name> <token>     Save account to Keychain"
    echo "  supawho rename <old> <new>     Rename a saved account
  supawho remove <name>          Remove account"
    echo "  supawho list                   List saved accounts"
    echo "  supawho use <name>             Login with specific account"
    echo -e "  supawho version                Show version\n"
    echo "Tokens are stored securely in macOS Keychain."
    ;;
  "")              cmd_interactive ;;
  *)               echo "Unknown command: $1"
                   echo "Run 'supawho help' for usage."
                   exit 1 ;;
esac